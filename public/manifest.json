{
  "name": "StingBuddy",
  "short_name": "StingBuddy",
  "description": "Task management that actually gets things done. Capture, organize, execute.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0f0f14",
  "theme_color": "#22c55e",
  "orientation": "any",
  "categories": ["productivity", "utilities"],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "New Task",
      "short_name": "Add",
      "url": "/inbox?action=new",
      "icons": [{ "src": "/icons/shortcut-add.png", "sizes": "96x96" }]
    },
    {
      "name": "Start Blitz",
      "short_name": "Blitz",
      "url": "/blitz",
      "icons": [{ "src": "/icons/shortcut-blitz.png", "sizes": "96x96" }]
    },
    {
      "name": "Today",
      "short_name": "Today",
      "url": "/today",
      "icons": [{ "src": "/icons/shortcut-today.png", "sizes": "96x96" }]
    },
    {
      "name": "Inbox",
      "short_name": "Inbox",
      "url": "/inbox",
      "icons": [{ "src": "/icons/shortcut-inbox.png", "sizes": "96x96" }]
    }
  ],
  "share_target": {
    "action": "/api/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
